# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Web app URLs
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI providers
# Mercury 2: Scribble format/title/transform/email/translate/publish.
MERCURY_API_KEY=
# Gemini: Minutes meeting-enhance + embeddings only.
GEMINI_API_KEY=

# Razorpay billing
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_MONTHLY=
RAZORPAY_PLAN_YEARLY=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Transactional email
RESEND_API_KEY=
RESEND_FROM=

# Desktop download page
NEXT_PUBLIC_APP_VERSION=0.10.1
NEXT_PUBLIC_GITHUB_REPO=navgurukul/oscar

# Observability (PostHog — US region). Used for the signup/usage funnel, web JS
# error tracking, and metadata-only LLM telemetry. Leave the key blank to fully
# disable (SDK no-ops).
NEXT_PUBLIC_POSTHOG_KEY=
# Dashboard/links host for the browser SDK (ingestion is proxied via /ingest).
# Defaults to https://us.posthog.com — only set to override the region.
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
# Server-side INGESTION host for posthog-node. Distinct from the UI host above —
# defaults to https://us.i.posthog.com. Do NOT set this to us.posthog.com.
POSTHOG_HOST=https://us.i.posthog.com
# Optional: Mercury per-1M-token price so $ai_total_cost_usd is populated. Unset
# → token counts + latency are still tracked, cost is omitted (never guessed).
MERCURY_PRICE_PER_1M_INPUT_USD=
MERCURY_PRICE_PER_1M_OUTPUT_USD=
