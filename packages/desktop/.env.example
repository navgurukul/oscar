# Desktop Vite build overrides. Release builds use safe defaults when unset.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_WEB_APP_URL=http://localhost:3000

# Dictation cleanup runs on the web /api/ai/dictation-cleanup route (Amplify
# Mercury) by default. Set to "false" to revert to the legacy Supabase
# ai-process edge function (escape hatch during QA); unset/anything else = web.
VITE_STREAM_CLEANUP_VIA_WEB=

# Optional Tauri dev-server host override.
TAURI_DEV_HOST=127.0.0.1
