# Desktop Vite build overrides. Release builds use safe defaults when unset.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_WEB_APP_URL=http://localhost:3000

# Route dictation cleanup through the web /api/ai/dictation-cleanup route
# (Amplify Mercury) instead of the Supabase ai-process edge function. "true"
# enables it; anything else (or unset) keeps the legacy edge path.
VITE_STREAM_CLEANUP_VIA_WEB=

# Optional Tauri dev-server host override.
TAURI_DEV_HOST=127.0.0.1
