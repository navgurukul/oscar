{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OSCAR",
  "version": "0.1.0",
  "identifier": "com.souvikdeb.oscar",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {},
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "OSCAR",
        "width": 900,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "deepLink": {
    "mobile": [{
      "host": "callback",
      "pathPrefix": ["/auth"]
    }],
    "desktop": {
      "schemes": ["oscar"]
    }
  }
}
